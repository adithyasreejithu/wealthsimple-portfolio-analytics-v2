  "portfolio_group_reference": {
    "Core": {
      "role_description": "Broad diversified foundation for long-term market exposure and compounding.",
      "security_patterns": [
        "broad market ETF",
        "global equity ETF",
        "total market ETF",
        "multi-asset allocation ETF"
      ],
      "sector_bias": "diversified across many sectors"
    },
    "Income": {
      "role_description": "Dividend, distribution, or yield-focused holdings.",
      "security_patterns": [
        "dividend ETF",
        "dividend stock",
        "bond ETF",
        "REIT",
        "income ETF"
      ],
      "sector_bias": [
        "Financials",
        "Utilities",
        "Energy",
        "Real Estate",
        "Consumer Staples",
        "Communication Services"
      ]
    },
    "Quality": {
      "role_description": "Established companies with durable business models and lower relative uncertainty than speculative growth holdings.",
      "security_patterns": [
        "large cap leader",
        "blue chip",
        "defensive business",
        "quality ETF"
      ],
      "sector_bias": [
        "Consumer Staples",
        "Financials",
        "Industrials",
        "Health Care",
        "Information Technology",
        "Communication Services"
      ]
    },
    "Growth": {
      "role_description": "Higher-growth companies, sector ETFs, or innovation themes with higher volatility.",
      "security_patterns": [
        "growth stock",
        "technology ETF",
        "semiconductor ETF",
        "innovation ETF",
        "cloud/software theme"
      ],
      "sector_bias": [
        "Information Technology",
        "Consumer Discretionary",
        "Communication Services",
        "Health Care",
        "Industrials"
      ]
    },
    "Alternatives": {
      "role_description": "Diversifiers outside traditional equities and income holdings.",
      "security_patterns": [
        "gold ETF",
        "commodity ETF",
        "precious metals",
        "alternative asset"
      ],
      "sector_bias": [
        "Materials",
        "Real Estate"
      ]
    },
    "Cash": {
      "role_description": "Uninvested capital or very short-duration cash-like holdings.",
      "security_patterns": [
        "cash",
        "money market",
        "t-bill ETF",
        "high interest savings ETF"
      ],
      "sector_bias": []
    }
  },
