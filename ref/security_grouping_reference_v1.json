      "Core",
      "Income",
      "Quality",
      "Growth",
      "Alternatives",
      "Cash"
    ],
    "usage": "Use this file as a reference for grouping securities based on metadata already stored in the database. Do not store this descriptive reference content redundantly in DuckDB runtime tables."
  },
