  "etf_reference": {
    "description": "ETF grouping reference. ETFs should be grouped using ETF name, ticker, objective, asset class, region, style, and holdings data if available.",
    "asset_classes": {
      "Broad Equity": {
        "keywords": [
          "total market",
          "all equity",
          "core equity",
          "global equity",
          "world equity",
          "s&p 500",
          "tsx",
          "msci world"
        ],
        "default_group_bias": [
          "Core"
        ]
      },
      "Dividend Equity": {
        "keywords": [
          "dividend",
          "dividend growth",
          "high dividend",
          "aristocrats",
          "income equity"
